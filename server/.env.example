# Server port
PORT=5000

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://localhost:27017/ciphersqlstudio

# PostgreSQL sandbox database credentials
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_pg_password
PG_DATABASE=ciphersqlstudio_sandbox

# Groq API key for hint generation
GROQ_API_KEY=your_groq_api_key_here

# JWT secret for authentication (change in production!)
JWT_SECRET=your_secret_key_here

# Frontend origin (use * for all origins in development)
CLIENT_ORIGIN=*
